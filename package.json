{
  "name": "initx-plugin-svg-writer",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.5.1",
  "description": "Interactive SVG writer plugin for initx",
  "author": "imba97",
  "license": "MIT",
  "homepage": "https://github.com/imba97/initx-plugin-svg-writer#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:imba97/initx-plugin-svg-writer.git"
  },
  "bugs": {
    "url": "https://github.com/imba97/initx-plugin-svg-writer/issues"
  },
  "keywords": [
    "initx",
    "initx-plugin",
    "svg",
    "icon"
  ],
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "stub": "unbuild --stub",
    "build": "unbuild",
    "release": "bumpp",
    "lint": "eslint --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "@initx-plugin/core": "*",
    "@initx-plugin/utils": "*"
  },
  "dependencies": {
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@initx-plugin/core": "^0.3.7",
    "@initx-plugin/utils": "^0.3.7",
    "@types/node": "^25.9.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --cache --fix"
  }
}
